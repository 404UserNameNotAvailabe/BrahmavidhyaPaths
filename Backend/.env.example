# Copy to .env and fill in real values. NEVER commit the real .env.

# --- PostgreSQL (Neon) ---
DB_HOST=your-neon-host.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=your-db-user
DB_PASSWORD=your-db-password
# "require" for managed Postgres (Neon/Supabase/Aiven), "disable" for local dev.
DB_SSLMODE=require

# --- Embeddings (semantic match layer) ---
# Leave everything blank to run fully self-contained (trigram + word-overlap only,
# nothing leaves your server).
#
# Vertex AI via ADC (recommended — paid tier, Google does NOT train on your data):
#   leave GEMINI_API_KEY blank, set the project + location, and point
#   GOOGLE_APPLICATION_CREDENTIALS at the service-account JSON key.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/opt/brahmavidya/gcp-sa.json
GEMINI_EMBED_MODEL=gemini-embedding-001
# Must equal the vector(N) dimension in sql/schema.sql.
EMBED_DIM=768

# --- Auth / login throttle (optional) ---
SESSION_TTL_HOURS=168          # 7 days
LOGIN_MAX_FAILS=5
LOGIN_WINDOW_SECONDS=900       # lock a username for 15 min after 5 failures

# --- CORS — set to your production frontend origin in prod ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
