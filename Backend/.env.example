# --- PostgreSQL ---
DB_HOST=ep-nameless-credit-aoqqywao.c-2.ap-southeast-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=npg_4ZKynAfLOra0
# "require" for managed Postgres (Neon/Supabase/Aiven), "disable" for local dev.
DB_SSLMODE=require

# --- Gemini embeddings (semantic match layer) ---
# Leave GEMINI_API_KEY blank to disable semantic matching (trigram + word-overlap still work).
# ADC mode (recommended for prod): leave GEMINI_API_KEY blank, set project + location,
# and point GOOGLE_APPLICATION_CREDENTIALS at the service account JSON key file.
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/etc/brahmavidya/service-account.json
GEMINI_EMBED_MODEL=gemini-embedding-001
# Must equal the vector(N) dimension in sql/migrate_v2.sql.
EMBED_DIM=768

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
